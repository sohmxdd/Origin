/* Origin TUI — Claude Code Style Cyan Theme */

Screen {
    background: #0d0d0d;
}

/* ── Header ────────────────────────────────────────────── */
#header-bar {
    dock: top;
    height: 6;
    background: #0d0d0d;
    color: #777777;
    padding: 0 2 0 2;
    border-bottom: solid #1e1e1e;
}

/* ── Content Switcher ──────────────────────────────────── */
#main-switcher {
    height: 1fr;
    background: #0d0d0d;
}

/* ── Welcome Screen (HomeView) ─────────────────────────── */
HomeView {
    padding: 1 2;
}

#welcome-card {
    background: #141414;
    border: solid #00ffd2;
    padding: 1 2;
    height: 16;
    margin-bottom: 1;
}

#welcome-title {
    color: #ffffff;
    text-style: bold;
    margin-bottom: 1;
}

#welcome-content {
    height: 1fr;
}

#welcome-brand {
    width: 40%;
    height: 100%;
    align: center middle;
}

#welcome-art {
    width: 100%;
    height: 9;
    content-align: center middle;
}

#welcome-logo {
    color: #00ffd2;
    text-style: bold;
    content-align: center middle;
    margin-top: 1;
}

#welcome-tagline {
    color: #777777;
    content-align: center middle;
}

#welcome-stats-pane {
    width: 60%;
    height: 100%;
    padding-left: 4;
}

#welcome-metadata {
    height: auto;
    color: #777777;
    margin-bottom: 1;
}

#welcome-metrics {
    height: auto;
    color: #777777;
    margin-bottom: 1;
}

#welcome-activity-header {
    color: #888888;
    text-style: bold;
    margin-bottom: 1;
}

#welcome-timeline-feed {
    height: 1fr;
}

#command-hints {
    color: #c0c0c0;
    background: #0d0d0d;
    padding: 1 0;
    margin-bottom: 1;
}

.section-header {
    color: #888888;
    text-style: bold;
    margin-top: 1;
    margin-bottom: 1;
}

.diagnostics-panel {
    height: 8;
    background: #141414;
    padding: 1 2;
    border: solid #1e1e1e;
}

/* ── Context View ──────────────────────────────────────── */
#context-markdown {
    background: #0d0d0d;
    padding: 1 2;
}

/* ── List Views & Inspector Layout ─────────────────────── */
.list-pane {
    background: #0d0d0d;
    padding: 0 1;
}

.inspector-pane {
    background: #141414;
    padding: 1 2;
}

/* Responsive Layout */
.wide .list-pane {
    width: 60%;
}

.wide .inspector-pane {
    width: 40%;
    border-left: solid #1e1e1e;
}

.narrow .inspector-pane {
    display: none;
}

.narrow.show-inspector .inspector-pane {
    display: block;
    width: 100%;
}

.narrow.show-inspector .list-pane {
    display: none;
}

/* ── ListViews & Scrollbars ────────────────────────────── */
ListView {
    background: #0d0d0d;
    scrollbar-background: #0d0d0d;
    scrollbar-color: #1e1e1e;
    scrollbar-color-active: #00ffd2;
    scrollbar-color-hover: #00ffd2;
}

ListView > ListItem {
    background: #0d0d0d;
    padding: 0 1;
}

ListView > ListItem.--highlight {
    background: #1e1e1e;
    color: #ffffff;
}

ListView:focus > ListItem.--highlight {
    background: #262626;
    color: #00ffd2;
    text-style: bold;
}

/* Day header inside timeline list */
.day-header {
    background: #0d0d0d;
    color: #777777;
    text-style: bold;
    margin-top: 1;
    margin-bottom: 1;
}

/* ── Command Input Bar at Bottom ────────────────────────── */
#command-input {
    dock: bottom;
    height: 3;
    background: #0d0d0d;
    border-top: solid #1e1e1e;
    layout: horizontal;
    padding: 0 1;
}

#input-prefix {
    color: #00ffd2;
    text-style: bold;
    margin-top: 1;
    width: auto;
}

#input-field {
    background: #0d0d0d;
    border: none;
    color: #ffffff;
    width: 1fr;
    height: 1;
    margin-top: 1;
    padding: 0;
}

#input-field:focus {
    border: none;
}

/* ── Status Bar / Status message ─────────────────────────── */
#status-message {
    dock: bottom;
    height: 1;
    background: #0d0d0d;
    color: #e2a855;
    padding: 0 2;
}

/* ── Splash Screen ─────────────────────────────────────── */
#splash-screen {
    background: #0d0d0d;
    align: center middle;
}

#splash-art {
    width: 100%;
    height: 100%;
    align: center middle;
    content-align: center middle;
    background: #0d0d0d;
}
